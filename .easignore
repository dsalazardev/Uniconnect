# EAS Build Ignore File
# Exclude files unnecessary for the build process

# Node modules (will be installed during build)
node_modules/

# Build outputs
build/
dist/
*.apk
*.aab
*.ipa

# Expo
.expo/
.expo-shared/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Large assets not needed for build
*.mp4
*.mov
*.avi
