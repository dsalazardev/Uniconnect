model event {
  id_event    Int       @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  time        String
  location    String
  type        EventType
  created_by  Int
  id_program  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  creator     user      @relation(fields: [created_by], references: [id_user], onDelete: Cascade)
  program     program?  @relation(fields: [id_program], references: [id_program])

  @@index([date])
  @@index([type])
  @@index([id_program])
  @@index([date, type])
  @@index([created_by])
  @@map("events")
}

enum EventType {
  CONFERENCIA
  TALLER
  SEMINARIO
  COMPETENCIA
  CULTURAL
  DEPORTIVO
}
