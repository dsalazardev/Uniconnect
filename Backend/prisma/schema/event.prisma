model event_category {
  id_category Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  color       String  @db.VarChar(20)
  events      event[]

  @@map("event_categories")
}

model event {
  id_event    Int            @id @default(autoincrement())
  id_category Int
  title       String         @db.VarChar(300)
  description String         @db.VarChar(2000)
  location    String         @db.VarChar(300)
  start_date  DateTime       @db.Timestamptz()
  end_date    DateTime       @db.Timestamptz()
  status      EventStatus    @default(UPCOMING)
  created_by  Int
  created_at  DateTime       @default(now()) @db.Timestamptz()
  category    event_category @relation(fields: [id_category], references: [id_category])
  creator     user           @relation(fields: [created_by], references: [id_user], onDelete: Cascade)

  @@index([id_category])
  @@index([status])
  @@index([start_date])
  @@index([created_by])
  @@map("events")
}

enum EventStatus {
  UPCOMING
  ONGOING
  FINISHED
  CANCELLED
}
