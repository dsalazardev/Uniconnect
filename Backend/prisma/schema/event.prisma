model event_category {
  id_category   Int                          @id @default(autoincrement())
  name          String                       @db.VarChar(100)
  color         String                       @db.VarChar(20)
  events        event[]
  subscriptions event_category_subscription[]

  @@map("event_categories")
}

model event_category_subscription {
  id_subscription Int            @id @default(autoincrement())
  id_user         Int
  id_category     Int
  created_at      DateTime       @default(now()) @db.Timestamptz()
  user            user           @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  category        event_category @relation(fields: [id_category], references: [id_category], onDelete: Cascade)

  @@unique([id_user, id_category])
  @@index([id_user])
  @@index([id_category])
  @@map("event_category_subscriptions")
}

model event {
  id_event    Int            @id @default(autoincrement())
  id_category Int
  title       String         @db.VarChar(300)
  description String         @db.VarChar(2000)
  location    String         @db.VarChar(300)
  start_date  DateTime       @db.Timestamptz()
  end_date    DateTime       @db.Timestamptz()
  status      EventStatus    @default(UPCOMING)
  created_by  Int
  created_at  DateTime       @default(now()) @db.Timestamptz()
  category    event_category @relation(fields: [id_category], references: [id_category])
  creator     user           @relation(fields: [created_by], references: [id_user], onDelete: Cascade)

  @@index([id_category])
  @@index([status])
  @@index([start_date])
  @@index([created_by])
  @@map("events")
}

enum EventStatus {
  UPCOMING
  ONGOING
  FINISHED
  CANCELLED
}
