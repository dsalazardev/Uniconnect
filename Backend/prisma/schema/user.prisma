model user {
  id_role                       Int
  id_user                       Int                            @id @default(autoincrement())
  full_name                     String                         @db.VarChar
  cell_phone                    String?                        @db.VarChar
  picture                       String?
  email                         String                         @db.VarChar
  id_program                    Int?
  current_semester              Int?
  google_sub                    String?                        @db.VarChar
  connections_adressee          connection[]                   @relation("ConnectionAdressee")
  connections_requester         connection[]                   @relation("ConnectionRequester")
  daily_digest_queue            daily_digest_queue[]
  enrollments                   enrollment[]
  events_created                event[]
  groups_owned                  group[]                        @relation("GroupOwner")
  groups_pending_owner          group[]                        @relation("GroupPendingOwner")
  invitations_received          group_invitation[]             @relation("GroupInvitee")
  invitations_sent              group_invitation[]             @relation("GroupInviter")
  group_join_requests           group_join_request[]
  memberships                   membership[]
  notifications                 notification[]
  push_token                    push_token[]
  token_blacklist               token_blacklist[]
  program                       program?                       @relation(fields: [id_program], references: [id_program])
  role                          role                           @relation(fields: [id_role], references: [id_role])
  user_notification_preferences user_notification_preference[]
  user_push_token               user_push_token[]
  polls_created                 poll[]                         @relation("PollCreator")
  poll_votes                    poll_vote[]                    @relation("PollVoter")
  forum_votes                   forum_vote[]                   @relation("ForumVoter")
  forum_questions               forum_question[]               @relation("ForumQuestionAuthor")
  forum_answers                 forum_answer[]                 @relation("ForumAnswerAuthor")
  event_category_subscriptions  event_category_subscription[]
}
