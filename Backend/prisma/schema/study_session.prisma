enum RecurrenceType {
  NONE
  WEEKLY
}

enum SessionInstanceStatus {
  ACTIVE
  CANCELLED
}

model study_session {
  id_session            Int                      @id @default(autoincrement())
  id_group              Int
  created_by            Int
  title                 String                   @db.VarChar
  description           String?                  @db.VarChar
  start_datetime        DateTime                 @db.Timestamptz(6)
  duration_minutes      Int
  recurrence_type       RecurrenceType           @default(NONE)
  recurrence_end_date   DateTime?                @db.Timestamptz(6)
  created_at            DateTime                 @default(now()) @db.Timestamptz(6)
  group                 group                    @relation(fields: [id_group], references: [id_group], onDelete: Cascade)
  creator               user                     @relation("SessionCreator", fields: [created_by], references: [id_user])
  instances             study_session_instance[]
}

model study_session_instance {
  id_instance    Int                   @id @default(autoincrement())
  id_session     Int
  scheduled_date DateTime              @db.Timestamptz(6)
  status         SessionInstanceStatus @default(ACTIVE)
  cancelled_at   DateTime?             @db.Timestamptz(6)
  cancelled_by   Int?
  session        study_session         @relation(fields: [id_session], references: [id_session], onDelete: Cascade)
  canceller      user?                 @relation("SessionCanceller", fields: [cancelled_by], references: [id_user])
}
