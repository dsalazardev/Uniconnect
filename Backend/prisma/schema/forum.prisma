enum ForumQuestionStatus {
  OPEN
  RESOLVED
}

enum ForumVoteEntityType {
  QUESTION
  ANSWER
}

model forum_question {
  id_question  Int                  @id @default(autoincrement())
  id_course    Int
  id_user      Int
  title        String               @db.VarChar(300)
  body         String               @db.VarChar(2000)
  status       ForumQuestionStatus  @default(OPEN)
  vote_count   Int                  @default(0)
  answer_count Int                  @default(0)
  created_at   DateTime             @default(now()) @db.Timestamptz(6)
  course       course               @relation(fields: [id_course], references: [id_course], onDelete: Cascade)
  author       user                 @relation("ForumQuestionAuthor", fields: [id_user], references: [id_user])
  answers      forum_answer[]
}

model forum_answer {
  id_answer   Int            @id @default(autoincrement())
  id_question Int
  id_user     Int
  body        String         @db.VarChar(2000)
  vote_count  Int            @default(0)
  is_accepted Boolean        @default(false)
  created_at  DateTime       @default(now()) @db.Timestamptz(6)
  question    forum_question @relation(fields: [id_question], references: [id_question], onDelete: Cascade)
  author      user           @relation("ForumAnswerAuthor", fields: [id_user], references: [id_user])
}

model forum_vote {
  id_vote     Int                 @id @default(autoincrement())
  id_user     Int
  entity_type ForumVoteEntityType
  entity_id   Int
  created_at  DateTime            @default(now()) @db.Timestamptz(6)
  user        user                @relation("ForumVoter", fields: [id_user], references: [id_user])

  @@unique([id_user, entity_type, entity_id])
}
