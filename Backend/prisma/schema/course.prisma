model course {
  id_course   Int          @id @default(autoincrement())
  name        String?      @db.VarChar
  id_program  Int?
  credits     Int?
  type        String?      @db.VarChar
  program     program?     @relation(fields: [id_program], references: [id_program])
  enrollments enrollment[]
  groups      group[]
}
