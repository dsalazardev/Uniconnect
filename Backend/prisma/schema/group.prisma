model group {
  id_group            Int                  @id @default(autoincrement())
  name                String?              @db.VarChar
  description         String?              @db.VarChar
  id_course           Int?
  owner_id            Int?
  /// ID del candidato a nuevo owner pendiente de aceptar la transferencia (US-W02)
  pending_owner_id    Int?
  created_at          DateTime             @default(now()) @db.Timestamptz(6)
  is_direct_message   Boolean              @default(false)
  files               file[]
  course              course?              @relation(fields: [id_course], references: [id_course])
  owner               user?                @relation("GroupOwner", fields: [owner_id], references: [id_user])
  pending_owner       user?                @relation("GroupPendingOwner", fields: [pending_owner_id], references: [id_user])
  group_invitation    group_invitation[]
  memberships         membership[]
  group_join_requests group_join_request[]
}
