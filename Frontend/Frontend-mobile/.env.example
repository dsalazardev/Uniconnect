# ─── Backend API ───────────────────────────────────────────────────────
# URL base del backend (cambiar según entorno: local, staging, producción)
EXPO_PUBLIC_API_URL=https://api.uniconnect.example.com/api

# ─── Google OAuth Client IDs ──────────────────────────────────────────
# Generar en Google Cloud Console > Credentials > OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ─── Auth0 ────────────────────────────────────────────────────────────
# Configuración del tenant de Auth0 (https://manage.auth0.com)
EXPO_PUBLIC_AUTH0_DOMAIN=dev-xxxxxxxxxxxxxxxx.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_AUTH0_AUDIENCE=https://dev-xxxxxxxxxxxxxxxx.us.auth0.com/api/v2/
