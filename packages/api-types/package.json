{
  "name": "@uniconnect/api-types",
  "version": "1.0.0",
  "description": "Tipos TypeScript y esquemas Zod autogenerados desde openapi.json de Uniconnect",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "openapi-typescript ../../openspec/openapi.json -o src/openapi.d.ts && openapi-zod-client ../../openspec/openapi.json -o src/schemas.ts --template schemas-template.hbs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "uniconnect",
    "api-types",
    "openapi",
    "typescript"
  ],
  "author": "Uniconnect Team",
  "license": "MIT",
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "openapi-zod-client": "^1.18.3",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
